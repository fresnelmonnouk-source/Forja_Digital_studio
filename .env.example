# .env.example — Variables d'environnement de FORJA
# Copier en .env (local) ou renseigner dans Vercel (prod).

# ── Obligatoires ────────────────────────────────────────────────
# Base de données PostgreSQL (Supabase : utiliser le POOLER, port 6543, en prod)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE"
# Validation stricte du certificat SSL DB (true en prod si le cert est valide)
DATABASE_SSL_STRICT="false"

# NextAuth
NEXTAUTH_SECRET="votre_secret_nextauth_32_chars_minimum"
NEXTAUTH_URL="https://ton-domaine.vercel.app"   # URL publique de prod

# LLM — au moins UNE clé requise (ordre de fallback : Anthropic → DeepSeek → OpenAI)
ANTHROPIC_API_KEY="sk-ant-..."
DEEPSEEK_API_KEY="sk-..."
# Modèle Anthropic. Défaut = Haiku. Mettre Sonnet pour plus de fiabilité :
# LLM_MODEL="claude-sonnet-4-6"

# ── Recommandées ────────────────────────────────────────────────
# Emails (OTP, reset) — sinon l'envoi échoue
RESEND_API_KEY="re_..."
RESEND_FROM="onboarding@resend.dev"             # ou "FORJA <no-reply@tondomaine.fr>"

# Rate limiting (sinon désactivé en repli)
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# ── Optionnelles (dégradation gracieuse si absentes) ────────────
# Génération d'images IA (couvertures DALL-E) + fallback
OPENAI_API_KEY="sk-..."
# Vraies photos (banque d'images Unsplash)
UNSPLASH_ACCESS_KEY="..."
# Recherche web de marché pour FORJA (méthode ORACLE)
TAVILY_API_KEY="tvly-..."

# Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN="https://xxx@sentry.io/xxx"
SENTRY_DSN="https://xxx@sentry.io/xxx"
SENTRY_AUTH_TOKEN="sntrys_xxxxx"
