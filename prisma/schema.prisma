generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  password      String
  role          String         @default("user") // "user" | "admin"
  freeDocsUsed  Int            @default(0)       // PDF gratuits consommés (quota 5 à vie)
  credits       Int            @default(0)       // crédits PDF achetés restants
  creditsExpireAt DateTime?                      // expiration des crédits (31j depuis le dernier achat)
  signupIp      String?                          // anti-fraude : IP d'inscription
  emailVerified DateTime?
  otpCode       String?
  otpExpires    DateTime?
  resetToken    String?        @unique
  resetExpires  DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  payments      Payment[]
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fedapayId String?  @unique // id de la transaction FedaPay
  packId    String              // identifiant du pack acheté
  amount    Int                 // montant en FCFA (XOF)
  credits   Int                 // crédits achetés
  status    String   @default("pending") // pending | approved | declined | canceled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model LegalPage {
  slug      String   @id // "mentions" | "cgu" | "confidentialite" | "remboursement"
  title     String
  content   String   @db.Text // markdown éditable depuis le back office
  updatedAt DateTime @updatedAt
}

model Conversation {
  id        String    @id @default(cuid())
  title     String?
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  role           String
  content        String       @db.Text
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}
